# PostgreSQL
POSTGRES_DB=rezea
POSTGRES_USER=rezea
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Backend API
SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
ENVIRONMENT=production
DEBUG=false
CORS_ORIGINS=["https://votre-domaine.com"]

# Email (MailerSend)
MAILERSEND_API_KEY=your_mailersend_api_key_here
MAILERSEND_FROM_EMAIL=noreply@votre-domaine.com

# Payment (HelloAsso)
HELLOASSO_CLIENT_ID=your_helloasso_client_id
HELLOASSO_CLIENT_SECRET=your_helloasso_client_secret
HELLOASSO_WEBHOOK_SECRET=your_webhook_secret

# Payment (Stripe - optionnel)
STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
