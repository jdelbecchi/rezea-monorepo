# HelloAsso Configuration

# Client ID et Secret obtenus depuis votre espace HelloAsso
# https://www.helloasso-sandbox.com/ (sandbox) ou https://www.helloasso.com/ (production)
HELLOASSO_CLIENT_ID=your_client_id_here
HELLOASSO_CLIENT_SECRET=your_client_secret_here

# Secret pour vérifier les webhooks (optionnel mais recommandé)
HELLOASSO_WEBHOOK_SECRET=your_webhook_secret_here

# Slug de votre association HelloAsso
HELLOASSO_ORGANIZATION_SLUG=your_organization_slug

# URLs de l'API (sandbox par défaut, changez pour production)
HELLOASSO_API_URL=https://api.helloasso-sandbox.com/v5
HELLOASSO_OAUTH_URL=https://api.helloasso-sandbox.com/oauth2/token

# URLs de retour après paiement
HELLOASSO_RETURN_URL=http://localhost:3000/dashboard/credits/callback
HELLOASSO_ERROR_URL=http://localhost:3000/dashboard/credits/error

# Pour la production, utilisez:
# HELLOASSO_API_URL=https://api.helloasso.com/v5
# HELLOASSO_OAUTH_URL=https://api.helloasso.com/oauth2/token
# HELLOASSO_RETURN_URL=https://votre-domaine.com/dashboard/credits/callback
# HELLOASSO_ERROR_URL=https://votre-domaine.com/dashboard/credits/error
