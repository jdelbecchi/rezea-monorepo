# Environment
ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://rezea:rezea_password@postgres:5432/rezea

# Security
SECRET_KEY=your-secret-key-change-in-production-min-32-chars-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Email (MailerSend)
MAILERSEND_API_KEY=your_mailersend_api_key
MAILERSEND_FROM_EMAIL=noreply@rezea.app

# Payment
HELLOASSO_CLIENT_ID=your_helloasso_client_id
HELLOASSO_CLIENT_SECRET=your_helloasso_client_secret
